{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/buyer",
      "dest": "/buyer/index.html"
    },
    {
      "src": "/seller", 
      "dest": "/seller/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/404.html",
      "status": 404
    }
  ]
}
