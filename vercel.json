{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/buyer",  "destination": "/buyer/index.html"  },
    { "source": "/seller", "destination": "/seller/index.html" }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key":   "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key":   "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
